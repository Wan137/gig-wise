# --- LLM ---
# Free API key from https://console.groq.com
GROQ_API_KEY=

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Local dev: SQLite. Production: a real Postgres URL (e.g. Supabase), since
# free hosts like Render don't offer a persistent disk on their free tier.
DATABASE_URL=sqlite:///./gigwise.db

# --- RAG / vector store ---
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- OCR ---
# Only needed if Tesseract is not on PATH (Windows local dev).
# Leave unset on Linux/Docker deploy targets.
TESSERACT_CMD=

# --- Uploads / chat ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=10485760
CHAT_HISTORY_LIMIT=10

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
